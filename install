#!/usr/bin/env bash

set -e

CONFIG="install.conf.yaml"
DOTBOT_DIR="dotbot"

DOTBOT_BIN="bin/dotbot"
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

cd "${BASEDIR}"
git -C "${DOTBOT_DIR}" submodule sync --quiet --recursive
git submodule update --init --recursive "${DOTBOT_DIR}"

# Install Homebrew if missing, then ensure it's in PATH for this process
_brew_installed() {
    command -v brew >/dev/null 2>&1 && return 0
    for homebrew_prefix in /opt/homebrew /home/linuxbrew/.linuxbrew "${HOME}/homebrew" /usr/local; do
        [ -x "${homebrew_prefix}/bin/brew" ] && return 0
    done
    return 1
}

if ! _brew_installed; then
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
for homebrew_prefix in /opt/homebrew /home/linuxbrew/.linuxbrew "${HOME}/homebrew" /usr/local; do
    if [ -x "${homebrew_prefix}/bin/brew" ]; then
        eval "$("${homebrew_prefix}/bin/brew" shellenv)"
        break
    fi
done

"${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" --plugin-dir dotbot-asdf -c "${CONFIG}" "${@}"
